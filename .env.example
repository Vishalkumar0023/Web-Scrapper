APP_ENV=local
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webscrapper
APP_STORE_BACKEND=auto
REDIS_URL=redis://localhost:6379/0
APP_QUEUE_BACKEND=auto
APP_QUEUE_KEY=queue:scrape:jobs
APP_EMBEDDED_WORKER=true
APP_EMBEDDED_WORKER_CONCURRENCY=1
APP_WORKER_MAX_RETRIES=3
APP_WORKER_RETRY_BACKOFF_INITIAL_SECONDS=2
APP_WORKER_RETRY_BACKOFF_MAX_SECONDS=30
APP_WORKER_JOB_LOCK_TTL_SECONDS=300
APP_AUTH_ENABLED=false
APP_AUTH_TOKENS_JSON=
APP_AUTH_DEV_TOKEN=dev-token
APP_AUTH_SIGNING_SECRET=change-me-local-auth-secret
APP_AUTH_TOKEN_TTL_SECONDS=86400
APP_AUTH_DEFAULT_WORKSPACE_ID=ws_default
APP_AUTH_DEFAULT_USER_ID=user_local
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_BACKEND=auto
APP_RATE_LIMIT_KEY_PREFIX=ratelimit:workspace
APP_RATE_LIMIT_REQUESTS_PER_WINDOW=120
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_EXPORT_STORAGE_BACKEND=local
APP_EXPORT_LOCAL_DIR=./exports
APP_EXPORT_SIGNED_URL_TTL_SECONDS=900
APP_EXPORT_SIGNING_SECRET=change-me-local-signing-secret
APP_BASE_URL=http://localhost:8000
APP_S3_BUCKET=
APP_S3_REGION=
APP_S3_ENDPOINT_URL=
APP_S3_ACCESS_KEY_ID=
APP_S3_SECRET_ACCESS_KEY=
APP_PLAYWRIGHT_FALLBACK=true
APP_PLAYWRIGHT_TIMEOUT_SECONDS=20
APP_DUPLICATE_ROW_CUTOFF_RATIO=0.8
APP_MAX_CONSECUTIVE_LOW_YIELD_PAGES=1
APP_AI_PLANNER_ENABLED=true
APP_AI_PROVIDER=gemini
AI_API_KEY=
APP_AI_MODEL=gemini-2.0-flash
APP_AI_TIMEOUT_SECONDS=12
APP_AI_MAX_SAMPLE_ROWS=8
APP_AI_MAX_CHARS_PER_VALUE=120
APP_AI_MAX_INPUT_CHARS=4000
APP_AI_MAX_ESTIMATED_INPUT_TOKENS=1200
APP_AI_MAX_OUTPUT_TOKENS=350
APP_AI_LABELING_PROMPT=
APP_DATA_RETENTION_DAYS=30
APP_STARTUP_CLEANUP_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://0.0.0.0:3000
CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|192\\.168\\.\\d{1,3}\\.\\d{1,3})(:\\d+)?$
SCRAPE_TIMEOUT_SECONDS=12
