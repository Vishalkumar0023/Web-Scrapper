APP_ENV=staging
API_PORT=8000
WEB_PORT=3000

DATABASE_URL=postgresql://webscrapper:change-me@staging-db:5432/webscrapper
APP_STORE_BACKEND=postgres

REDIS_URL=redis://staging-redis:6379/0
APP_QUEUE_BACKEND=redis
APP_QUEUE_KEY=queue:scrape:jobs

APP_EMBEDDED_WORKER=false
APP_EMBEDDED_WORKER_CONCURRENCY=2
APP_WORKER_MAX_RETRIES=3
APP_WORKER_RETRY_BACKOFF_INITIAL_SECONDS=2
APP_WORKER_RETRY_BACKOFF_MAX_SECONDS=30
APP_WORKER_JOB_LOCK_TTL_SECONDS=300

APP_AUTH_ENABLED=true
APP_AUTH_TOKENS_JSON={"staging-admin-token":{"user_id":"svc_staging_admin","workspace_id":"ws_staging","project_ids":["*"],"role":"admin"}}
APP_AUTH_DEV_TOKEN=
APP_AUTH_SIGNING_SECRET=change-me-staging-auth-secret
APP_AUTH_TOKEN_TTL_SECONDS=86400
APP_AUTH_DEFAULT_WORKSPACE_ID=ws_staging
APP_AUTH_DEFAULT_USER_ID=svc_staging_api

APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_BACKEND=redis
APP_RATE_LIMIT_KEY_PREFIX=ratelimit:staging
APP_RATE_LIMIT_REQUESTS_PER_WINDOW=180
APP_RATE_LIMIT_WINDOW_SECONDS=60

APP_EXPORT_STORAGE_BACKEND=s3
APP_EXPORT_LOCAL_DIR=./exports
APP_EXPORT_SIGNED_URL_TTL_SECONDS=900
APP_EXPORT_SIGNING_SECRET=change-me-staging-signing-secret
APP_BASE_URL=https://staging-api.example.com
APP_S3_BUCKET=webscrapper-staging-exports
APP_S3_REGION=ap-south-1
APP_S3_ENDPOINT_URL=
APP_S3_ACCESS_KEY_ID=
APP_S3_SECRET_ACCESS_KEY=

APP_PLAYWRIGHT_FALLBACK=true
APP_PLAYWRIGHT_TIMEOUT_SECONDS=20
APP_DUPLICATE_ROW_CUTOFF_RATIO=0.8
APP_MAX_CONSECUTIVE_LOW_YIELD_PAGES=1

APP_AI_PLANNER_ENABLED=true
APP_AI_PROVIDER=gemini
AI_API_KEY=
APP_AI_MODEL=gemini-2.0-flash
APP_AI_TIMEOUT_SECONDS=12
APP_AI_MAX_SAMPLE_ROWS=8
APP_AI_MAX_CHARS_PER_VALUE=120
APP_AI_MAX_INPUT_CHARS=4000
APP_AI_MAX_ESTIMATED_INPUT_TOKENS=1200
APP_AI_MAX_OUTPUT_TOKENS=350
APP_AI_LABELING_PROMPT=

APP_DATA_RETENTION_DAYS=30
APP_STARTUP_CLEANUP_ENABLED=true
CORS_ORIGINS=https://staging-web.example.com
SCRAPE_TIMEOUT_SECONDS=12
